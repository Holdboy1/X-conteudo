  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "dependencies": {
    "express": "^4.18.2",
    "discord.js": "^14.14.1",
    "twitter-api-v2": "^1.15.2",
    "node-cron": "^3.0.3",
    "lowdb": "^7.0.1",
    "dotenv": "^16.4.5",
    "openai": "^4.28.4",
    "@google/generative-ai": "^0.2.1",
    "cors": "^2.8.5"
  },
  "devDependencies": {
