{
  "crons": [
    {
      "path": "/api/cron/daily-post",
      "schedule": "30 * * * *"
    }
  ],
  "functions": {
    "api/cron/daily-post.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
